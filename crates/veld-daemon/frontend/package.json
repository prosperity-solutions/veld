{
  "name": "@veld/browser-assets",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "build:dev": "node build.mjs --dev",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "node build.mjs && echo 'Open http://localhost:3456/frontend/dev/' && python3 -m http.server 3456 -d .."
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "jsdom": "^29.0.1",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
